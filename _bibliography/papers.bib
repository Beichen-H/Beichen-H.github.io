@article{liu2026discerning,
  abbr={Education and Information Technologies},
  title={The Discerning Principal: What Prompting-Uptake Behaviors Characterize High Performers in Human-AI Collaboration?},
  author={Liu, Hui and Xu, Y. and Hu, Beichen and Dong, B.},
  journal={Education and Information Technologies},
  year={2026},
  selected={true},
  note={Under Review},
  pdf={Beichen_Hu_Discerning_Principal.pdf},
  abstract={As Generative AI (GAI) reshapes learning, exploring interaction behaviors is crucial for enhancing human-AI collaboration. This study uses Random Forest analysis to examine the behaviors of high vs. low performers (n=24) in an innovative instructional design task[cite: 10, 11, 56, 57]. Results characterize high performers as "discerning principals" with five core traits: intentionality, expertise-based judgment, strategic rejection, reflective adaptation, and systemic orchestration. These findings provide pedagogical insights for restructuring human-AI interaction frameworks[cite: 57].}
}

@article{hu2025intelligence,
  abbr={Shanghai Ed},
  title={Intelligence Amplification: Cultivating Deep Thinking in the AI Era},
  author={Hu, Beichen and Liu, Hui},
  journal={Shanghai Education: Global Education},
  issue={35},
  pages={56--61},
  year={2025},
  month={12},
  selected={true},
  pdf={Beichen_Hu_Intelligence_Amplification.pdf},
  abstract={Intelligence Amplification (IA) emphasizes AI as an amplifier of human thought rather than a replacement[cite: 162, 169]. This paper explores how educators can integrate AI into classrooms to foster deep thinking through four practical paths: co-creating human-AI ethical standards, promoting lateral reading for source literacy, designing "AI-empowered" high-order assignments, and building an "evaluation-feedback-optimization" loop[cite: 162, 169, 174, 226].}
}
